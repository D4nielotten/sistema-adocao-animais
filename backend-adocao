const express = require("express");

const mongoose = require("mongoose");

const cors = require("cors");

const app = express();

app.use(cors());

app.use(express.json());

// substitua pela string de conexão do seu cluster MongoDB
mongoose.connect("SUA_URL_AQUI")

.then(() => console.log("Banco conectado"))

.catch(err => console.log(err));

// esquema usado nas rotas de animais
const Animal = mongoose.model("Animal", {

  nome: String,

  especie: String,

  porte: String,

  descricao: String

});

// POST /animais — persiste um novo registro
app.post("/animais", async (req, res) => {

  const animal = new Animal(req.body);

  await animal.save();

  res.send("Animal salvo!");

});

// GET /animais — devolve tudo que está na coleção
app.get("/animais", async (req, res) => {

  const animais = await Animal.find();

  res.json(animais);

});

app.listen(3000, () => {

  console.log("Servidor rodando em http://localhost:3000");

});
